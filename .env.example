# -----------------------------------------------------------------------------
# Todas as variáveis abaixo são criadas AUTOMATICAMENTE pela integração
# Vercel + Supabase (marketplace). Em produção, você não precisa setar manualmente.
# Este arquivo serve como referência e pro desenvolvimento local (.env).
# -----------------------------------------------------------------------------

# --- Postgres (Supabase) ---
# Pooled (use em runtime serverless)
POSTGRES_URL=postgres://postgres.xxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
# Direct (use em migrations / drizzle-kit)
POSTGRES_URL_NON_POOLING=postgres://postgres.xxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase API (server-side) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=...

# --- Supabase client (exposto ao browser, VITE_ obrigatório) ---
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Supabase Inventory (outro projeto, source dos dados de estoque) ---
# Estas NÃO são criadas pela integração — você adiciona manualmente.
SUPABASE_INVENTORY_URL=https://yyy.supabase.co
SUPABASE_INVENTORY_ANON_KEY=eyJhbGc...

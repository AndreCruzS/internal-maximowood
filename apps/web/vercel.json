{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/cron/sync-inventory", "destination": "/api/cron/sync-inventory" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": { "maxDuration": 30 },
    "api/cron/sync-inventory.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/sync-inventory",
      "schedule": "0 11 * * *"
    }
  ]
}

# -----------------------------------------------------------------------------
# All variables below are auto-provisioned by the Vercel + Supabase
# marketplace integration on production/preview deployments. You do NOT need
# to set them manually there. This file exists for:
#   - Local development (copy to .env at repo root).
#   - Reference when reviewing which env vars the platform depends on.
# -----------------------------------------------------------------------------

# --- Postgres (Supabase) ---
# Pooled — use at serverless runtime (API routes, tRPC, Vercel functions).
POSTGRES_URL=postgres://postgres.xxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
# Direct — use for migrations and any session-mode DDL (drizzle-kit).
POSTGRES_URL_NON_POOLING=postgres://postgres.xxx:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase API (server-side, do NOT expose to browser) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=...

# --- Supabase client (exposed to browser; VITE_ prefix required for Vite) ---
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Supabase Inventory (separate project: source of inventory data) ---
# NOT provisioned by the integration — add these manually on Vercel.
SUPABASE_INVENTORY_URL=https://yyy.supabase.co
SUPABASE_INVENTORY_ANON_KEY=eyJhbGc...
